# =========================
# Go build artifacts
# =========================
/bin/
/dist/
/build/
*.exe
*.out
*.test
*.prof

# Go test cache
.coverage
*.coverprofile

# =========================
# Go modules / tooling
# =========================
/vendor/
go.work
go.work.sum

# =========================
# Local databases & state
# =========================
*.db
*.db-lock
*.bolt
*.sqlite
*.sqlite3

# Validator runtime state
validator.db
validator*.db

# =========================
# Environment & secrets
# =========================
.env
.env.*
*.key
*.pem
*.seed
*.secret
# deploy secrets bundle — cmd/_gentestnet writes these OUTSIDE the repo; ignored here as
# defense-in-depth in case a secrets-dir is ever pointed inside the tree. NOTE: config/testnet.json
# is the PUBLIC manifest and is intentionally NOT ignored.
deploy-bundles/
sim.env
genesis-seed.hex
MAPPING.txt
private.csv
public.csv
RIDLIST.csv

# NEVER commit validator seed
*VALIDATOR_SEED*
*seed.hex*

# =========================
# Logs & runtime output
# =========================
*.log
logs/
tmp/
temp/

# =========================
# OS / editor junk
# =========================
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db

# VS Code
.vscode/
*.code-workspace

# IntelliJ / GoLand
.idea/
*.iml

# =========================
# Protobuf generated files
# (uncomment if you want them generated, not committed)
# =========================
# internal/proto/*.pb.go

